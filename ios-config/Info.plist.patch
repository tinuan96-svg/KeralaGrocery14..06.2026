<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ios-config/Info.plist.patch
  ───────────────────────────
  Merge these keys into ios/App/App/Info.plist after running `npx cap add ios`.
  In Xcode you can paste them directly into the Info.plist source editor,
  or run the helper command:  node scripts/patch-info-plist.js
-->
<plist version="1.0">
<dict>

  <!-- ── App display name ─────────────────────────────────────────────── -->
  <key>CFBundleDisplayName</key>
  <string>KeralaGrocery</string>

  <key>CFBundleName</key>
  <string>KeralaGrocery</string>

  <key>CFBundleIdentifier</key>
  <string>com.keralagrocery.app</string>

  <key>CFBundleShortVersionString</key>
  <string>1.0.0</string>

  <key>CFBundleVersion</key>
  <string>1</string>

  <!-- ── Minimum iOS ───────────────────────────────────────────────────── -->
  <key>MinimumOSVersion</key>
  <string>15.0</string>

  <!-- ── Status bar: hidden at launch (Capacitor SplashScreen handles it) -->
  <key>UIStatusBarHidden</key>
  <false/>

  <key>UIStatusBarStyle</key>
  <string>UIStatusBarStyleLightContent</string>

  <key>UIViewControllerBasedStatusBarAppearance</key>
  <true/>

  <!-- ── Device orientation ────────────────────────────────────────────── -->
  <key>UISupportedInterfaceOrientations</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
  </array>
  <key>UISupportedInterfaceOrientations~ipad</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
    <string>UIInterfaceOrientationLandscapeLeft</string>
    <string>UIInterfaceOrientationLandscapeRight</string>
  </array>

  <!-- ── URL schemes for deep links and Google OAuth callback ──────────── -->
  <key>CFBundleURLTypes</key>
  <array>
    <!-- Main app scheme -->
    <dict>
      <key>CFBundleURLName</key>
      <string>com.keralagroceries.app</string>
      <key>CFBundleURLSchemes</key>
      <array>
        <string>kgapp</string>
      </array>
    </dict>
    <!-- Google Sign-In reversed client ID — replace GOOGLE_CLIENT_ID below -->
    <dict>
      <key>CFBundleURLName</key>
      <string>google-signin</string>
      <key>CFBundleURLSchemes</key>
      <array>
        <string>com.googleusercontent.apps.GOOGLE_CLIENT_ID</string>
      </array>
    </dict>
  </array>

  <!-- ── Universal Links / Associated Domains ──────────────────────────── -->
  <!-- Also add applinks:keralagrocery.com in the Xcode Signing & Capabilities
       tab under Associated Domains. This plist entry is just documentation. -->

  <!-- ── App Transport Security — production HTTPS only ───────────────── -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSAllowsArbitraryLoads</key>
    <false/>
    <key>NSAllowsArbitraryLoadsInWebContent</key>
    <false/>
  </dict>

  <!-- ── Privacy usage descriptions (App Store requirement) ───────────── -->
  <key>NSPhotoLibraryUsageDescription</key>
  <string>Kerala Groceries needs access to your photos to let you update your profile picture.</string>

  <key>NSCameraUsageDescription</key>
  <string>Kerala Groceries needs camera access to let you take a profile photo.</string>

  <key>NSLocationWhenInUseUsageDescription</key>
  <string>Kerala Groceries uses your location to suggest your nearest delivery address.</string>

  <key>NSUserNotificationsUsageDescription</key>
  <string>Kerala Groceries sends notifications about your order status and exclusive offers.</string>

  <!-- ── Face ID / Biometrics (future use) ─────────────────────────────── -->
  <key>NSFaceIDUsageDescription</key>
  <string>Kerala Groceries can use Face ID to sign in securely.</string>

  <!-- ── Background modes — push notifications ─────────────────────────── -->
  <key>UIBackgroundModes</key>
  <array>
    <string>remote-notification</string>
    <string>fetch</string>
  </array>

  <!-- ── Launch screen storyboard ──────────────────────────────────────── -->
  <key>UILaunchStoryboardName</key>
  <string>LaunchScreen</string>

  <!-- ── Scene configuration (required for iOS 13+) ──────────────────── -->
  <key>UIApplicationSceneManifest</key>
  <dict>
    <key>UIApplicationSupportsMultipleScenes</key>
    <false/>
    <key>UISceneConfigurations</key>
    <dict/>
  </dict>

</dict>
</plist>
